{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/agent-gate.py\" PreToolUse",
            "type": "command"
          }
        ],
        "matcher": "Bash|Write|Edit|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime --hook-json",
            "type": "command"
          },
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/agent-gate.py\" SessionStart",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/agent-gate.py\" UserPromptSubmit",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  }
}
