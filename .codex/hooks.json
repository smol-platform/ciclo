{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "bd codex-hook PostCompact",
            "statusMessage": "Scheduling Beads context refresh",
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/agent-gate.py\" PreToolUse",
            "statusMessage": "Checking Ciclo guardrails",
            "type": "command"
          }
        ],
        "matcher": "Bash|apply_patch|Edit|Write"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd codex-hook PreCompact",
            "statusMessage": "Checking Beads context",
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd codex-hook SessionStart",
            "statusMessage": "Loading Beads context",
            "type": "command"
          },
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/agent-gate.py\" SessionStart",
            "statusMessage": "Loading Ciclo guardrails",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bd codex-hook UserPromptSubmit",
            "statusMessage": "Refreshing Beads context",
            "type": "command"
          },
          {
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/agent-gate.py\" UserPromptSubmit",
            "statusMessage": "Refreshing Ciclo guardrails",
            "type": "command"
          }
        ]
      }
    ]
  }
}
