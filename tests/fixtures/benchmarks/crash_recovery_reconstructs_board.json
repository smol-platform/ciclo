  "expected": {"response_kinds": ["report_feedback", "recover_state"], "evidence_includes": ["ciclo.restart:after_crash", "remote.session.state:working", "worker.process:missing"], "required_actions": ["reconstruct_board_state", "resume_remote_monitoring", "preserve_existing_claims", "cleanup_dead_local_session", "avoid_duplicate_work"]},
