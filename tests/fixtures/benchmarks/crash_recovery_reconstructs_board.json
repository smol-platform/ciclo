  "loop": {"id": "expanded-orchestration-bench", "kind": "beads_work", "goal": "Reconstruct orchestration state after controller crash.", "harnesses": ["codex", "claude-code"], "dry_run": true},
  "policy": {"mode": "supervised", "require_approval_for": ["destructive_command"], "allow_commands": ["just check", "herdr attach remote-load-test"]},
