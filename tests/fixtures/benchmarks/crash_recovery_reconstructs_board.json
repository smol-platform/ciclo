  "herdr_events": [{"source": "fixture", "target": "remote-load-test", "harness": "codex", "state": "working", "cwd": "/workspace/project", "agent_label": "Remote load test", "evidence": ["remote.session.state:working", "controller.recovered:true"]}, {"source": "fixture", "target": "local-lint-worker", "harness": "claude-code", "state": "unknown", "cwd": ".worktrees/local-lint", "agent_label": "Local lint worker", "evidence": ["worker.process:missing", "worktree.path:.worktrees/local-lint"]}],
