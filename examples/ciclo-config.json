{
  "secrets": {
    "providers": [
      {
        "id": "corp-openbao",
        "kind": "openbao",
        "name": "Corporate OpenBao",
        "command": "bao"
      },
      {
        "id": "team-1password",
        "kind": "onepassword",
        "name": "Team 1Password",
        "command": "op"
      },
      {
        "id": "team-1password-connect",
        "kind": "onepassword-connect",
        "name": "Team 1Password Connect",
        "endpoint": "https://connect.example.invalid",
        "tokenEnv": "OP_CONNECT_TOKEN",
        "defaultVaultId": "replace-with-vault-uuid"
      },
      {
        "id": "team-keychain",
        "kind": "keychain",
        "name": "Team Keychain Plugin",
        "pluginProviderId": "keychain-test"
      }
    ]
  },
  "mcp": {
    "clients": ["claude", "codex"],
    "serverName": "ciclo",
    "command": "ciclo",
    "vars": {
      "CICLO_REUSE_HERDR_SESSION": "true"
    },
    "additionalServers": {
      "filesystem": {
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "."],
        "env": {
          "MCP_FS_MODE": "workspace"
        }
      },
      "github": {
        "command": "github-mcp-server",
        "args": ["stdio"],
        "env": {
          "GITHUB_PERSONAL_ACCESS_TOKEN": "Bearer ${secret://team-1password/Ciclo/API/token}"
        }
      }
    },
    "secretBindings": [
      {
        "name": "API_TOKEN",
        "providerId": "team-1password",
        "ref": "op://Ciclo/API/token",
        "reason": "Provide task-scoped API access to spawned worker MCP tools."
      },
      {
        "name": "OPENBAO_TOKEN",
        "providerId": "corp-openbao",
        "ref": "secret/data/ciclo/mcp",
        "field": "token",
        "reason": "Provide OpenBao-backed access to spawned worker MCP tools."
      },
      {
        "name": "PLUGIN_BACKED_API_TOKEN",
        "providerId": "team-keychain",
        "ref": "keychain://ciclo/example-api-token",
        "format": "Bearer ${secret}",
        "reason": "Example plugin-backed secret injected into the generated Ciclo MCP server config."
      },
      {
        "name": "CONNECT_API_TOKEN",
        "providerId": "team-1password-connect",
        "ref": "op-connect://replace-with-vault-uuid/replace-with-item-uuid/api_token",
        "reason": "Example 1Password Connect secret injected into the generated Ciclo MCP server config."
      }
    ],
    "workerSecretBindings": [
      {
        "name": "GITHUB_TOKEN",
        "providerId": "team-1password",
        "ref": "op://Ciclo/GitHub/token",
        "reason": "Provide GitHub CLI access to spawned worker shell tools."
      }
    ],
    "claudeChannel": false
  },
  "prompts": {
    "systemInjections": [
      {
        "id": "project-goals",
        "scope": "all",
        "text": "Prefer small, demoable changes. Keep project memory current in Beads and surface blockers promptly."
      },
      {
        "id": "brain-monitoring-help",
        "scope": "brain",
        "text": "When sessions stall, compare model fit, context size, validation state, PR status, and whether operator feedback is needed."
      }
    ]
  },
  "memory": {
    "enabled": true,
    "compactAfterDays": 14,
    "archiveAfterDays": 90,
    "minCompoundEntries": 3,
    "maxSummaryCharacters": 1600,
    "defaultImportance": "normal"
  },
  "heartbeat": {
    "preemptiveWork": {
      "enabled": true,
      "loopId": "preemptive-beads",
      "harnessId": "codex",
      "issueTypes": ["epic", "feature"],
      "maxConcurrent": 10,
      "isolation": "worktree",
      "configureMcp": true
    }
  },
  "cron": {
    "jobs": [
      {
        "id": "memory-compact-daily",
        "enabled": true,
        "description": "Age, compact, archive, and compound Ciclo memory every day.",
        "schedule": {
          "dailyAt": "03:30"
        },
        "task": {
          "kind": "memory_compact"
        }
      },
      {
        "id": "preemptive-work-scan",
        "enabled": true,
        "description": "Let the internal heartbeat scan configured Beads-ready work on an interval.",
        "schedule": {
          "everyMs": 900000
        },
        "task": {
          "kind": "dispatch_ready_work"
        }
      }
    ]
  },
  "remote": {
    "runnerKind": "kubernetes",
    "imageResolver": {
      "strategy": "variant",
      "registry": "ghcr.io",
      "repository": "smol-platform/ciclo",
      "tag": "latest"
    },
    "repoUrl": "https://github.com/example/project.git",
    "repoPath": "/workspace/project",
    "herdrSession": "project",
    "sshUser": "ciclo",
    "repoBootstrap": {
      "enabled": true,
      "useDevenv": true
    },
    "vars": {
      "CICLO_REMOTE_MODE": "interactive"
    },
    "egress": {
      "enabled": true,
      "cidrs": [
        "140.82.112.0/20"
      ],
      "domains": [
        "github.com",
        "api.github.com",
        "registry.npmjs.org"
      ]
    },
    "wireGuard": {
      "interfaceName": "wg-ciclo",
      "networkCidr": "10.44.0.0/24",
      "cicloAddress": "10.44.0.1/24",
      "runnerAddress": "10.44.0.2/24",
      "cicloEndpoint": "vpn.example.invalid:51820",
      "runnerPrivateKeySecretRef": "ciclo/wireguard/runner_private_key",
      "cicloPublicKeySecretRef": "ciclo/wireguard/ciclo_public_key",
      "cicloPrivateKeySecretRef": "ciclo/wireguard/ciclo_private_key",
      "runnerPublicKeySecretRef": "ciclo/wireguard/runner_public_key",
      "existingConfigSecretName": "project-wireguard-runner",
      "persistentKeepaliveSeconds": 25,
      "hostRouting": {
        "enabled": true,
        "serviceCidrs": [
          "192.168.0.0/16"
        ],
        "egressInterface": "auto",
        "masquerade": true
      }
    },
    "kubernetes": {
      "namespace": "ciclo-runners",
      "serviceAccount": "ciclo-runner",
      "mode": "statefulset",
      "statefulSetName": "ciclo-project-runner",
      "serviceName": "ciclo-project-runner-headless",
      "replicas": 1,
      "storageSize": "20Gi"
    },
    "awsLambda": {
      "microVmImageName": "ciclo-project-image",
      "microVmName": "ciclo-project-runner",
      "baseImageArn": "arn:aws:lambda:us-east-1:aws:microvm-image/nodejs22",
      "buildRoleArn": "arn:aws:iam::123456789012:role/ciclo-runner-build",
      "executionRoleArn": "arn:aws:iam::123456789012:role/ciclo-runner",
      "sourceS3Uri": "s3://ciclo-runner-artifacts/project.tar",
      "memoryMb": 2048,
      "vcpuCount": 2
    },
    "cloudflare": {
      "accountId": "replace-with-account-id",
      "workerName": "ciclo-project-runner"
    }
  }
}
